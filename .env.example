# .env.example — Generic. Copy to .env and fill values. NEVER commit .env.

APP_NAME=LLM Agent Framework
APP_ENV=production
DEBUG=false
CORS_ORIGINS=["https://yourdomain.com"]
API_VERSION=v1

# Security
WIDGET_API_KEY=generate-a-strong-random-key-here
ADMIN_API_KEY=generate-a-different-strong-key-here
ALLOWED_INPUT_MAX_LENGTH=500

# LLM
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-20250514
AGENT_MAX_ITERATIONS=5
AGENT_TOKEN_BUDGET_DAILY=50000
MEMORY_TOP_K=3

# Knowledge base mode:
#   off     — no KB (LLM uses system prompt only). Default.
#   context — stuff a static markdown KB file into the cached system prompt.
#             Best for small corpora (<50 posts).
#   rag     — retrieve top-K chunks from pgvector per query. Best for large
#             or growing corpora. Requires VOYAGE_API_KEY.
KB_MODE=off
KB_TOP_K=5
KB_CONTEXT_FILE=

# Embeddings (Voyage AI) — only consulted when KB_MODE=rag. Leave blank to
# fall back to a deterministic hash embedder (tests / local-dev only).
# voyage-3-large = 1024 dims, voyage-3-lite = 512 dims. The dim must match
# the pgvector column dim (set in alembic migrations).
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3-large
VOYAGE_EMBEDDING_DIM=1024

# Async Jobs
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/1
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/2
RUN_RESULT_TTL_SECONDS=3600

# Database (Supabase)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
DB_POOL_SIZE=5

# Redis
REDIS_PASSWORD=generate-a-strong-redis-password
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379
SESSION_TTL_SECONDS=3600
TOOL_CACHE_TTL_SECONDS=86400

# Rate Limiting
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60

# Guardrails — JSON list format
INJECTION_PATTERNS=["ignore previous instructions","forget your rules","jailbreak"]
FORBIDDEN_OUTPUT_PATTERNS=["diagnose","prescribe","treatment plan"]

# Persona
PERSONA_NAME=Assistant
AGENT_NAME=default

# Observability
SENTRY_DSN=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LOG_LEVEL=INFO
